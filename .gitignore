# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cloudflare
.wrangler
.open-next
worker-configuration.d.ts

# claude code local state (track settings.json + team skills, ignore everything else)
/.claude/*
!/.claude/settings.json
!/.claude/skills/
!/.claude/skills/**

# blog seed scripts: runtime tmp SQL only
scripts/.tmp-*.sql
